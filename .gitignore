# ═══════════════════════════════════════════════════════════════
# ملفات الإعدادات المحلية
# ═══════════════════════════════════════════════════════════════
config/database.php
config/config.local.php
.env
.env.local
.env.*.local

# ═══════════════════════════════════════════════════════════════
# ملفات النشر والاستضافة - Deployment Files
# ═══════════════════════════════════════════════════════════════
deploy.txt
deploy.bat
.installed

# ═══════════════════════════════════════════════════════════════
# النسخ الاحتياطية والملفات المرفوعة
# ═══════════════════════════════════════════════════════════════
backups/
uploads/

# ═══════════════════════════════════════════════════════════════
# ملفات الكاش والجلسات
# ═══════════════════════════════════════════════════════════════
cache/*
!cache/.gitkeep
sessions/*
!sessions/.gitkeep

# ═══════════════════════════════════════════════════════════════
# سجلات الأخطاء
# ═══════════════════════════════════════════════════════════════
error_log
php_errors.log
debug.log
*.log
logs/*
!logs/.gitkeep

# ═══════════════════════════════════════════════════════════════
# ملفات قاعدة البيانات
# ═══════════════════════════════════════════════════════════════
*.sql.bak
*.sql.gz
*.bak
*.backup
*.old

# ═══════════════════════════════════════════════════════════════
# ملفات Composer (إذا كنت تستخدمه)
# ═══════════════════════════════════════════════════════════════
/vendor/
composer.lock

# ═══════════════════════════════════════════════════════════════
# ملفات Node.js (إذا كنت تستخدمها)
# ═══════════════════════════════════════════════════════════════
node_modules/
package-lock.json

# ═══════════════════════════════════════════════════════════════
# ملفات التصدير والتقارير المؤقتة
# ═══════════════════════════════════════════════════════════════
exports/*
!exports/.gitkeep
temp/*
!temp/.gitkeep

# ═══════════════════════════════════════════════════════════════
# ملفات النظام
# ═══════════════════════════════════════════════════════════════
Thumbs.db
Desktop.ini
.DS_Store
ehthumbs.db
$RECYCLE.BIN/

# ═══════════════════════════════════════════════════════════════
# ملفات IDEs الإضافية
# ═══════════════════════════════════════════════════════════════
.vscode/
.idea/
*.code-workspace
.project
.settings/
*.sublime-project
*.sublime-workspace
nbproject/

# ═══════════════════════════════════════════════════════════════
# ملفات الاختبار والتطوير
# ═══════════════════════════════════════════════════════════════
test.php
debug.php
phpinfo.php